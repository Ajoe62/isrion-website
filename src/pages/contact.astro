---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import ContactForm from "../components/ContactForm.astro";
import { company, socials } from "../data/site";

const mapQuery = encodeURIComponent("Kubwa, Abuja, FCT, Nigeria");
---
<BaseLayout title={`Contact Us — ${company.name}`}>
  <PageHero
    current="Contact Us"
    eyebrow="Get in touch"
    title="Let's talk about your project."
    subtitle="Whether you're a government agency, industry leader or development organisation, our team is ready to support your next project."
    image="/img/contact-hero.jpg"
  />

  <section class="contact-section"><div class="wrap">
    <div class="contact-grid">
      <!-- INFO COLUMN -->
      <div class="contact-info on-dark">
        <span class="eyebrow on-dark" data-reveal>Reach us</span>
        <h2 data-reveal>Contact details.</h2>

        <div class="info-item" data-reveal>
          <h4>Office</h4>
          <p>{company.address}</p>
        </div>
        <div class="info-item" data-reveal>
          <h4>Email</h4>
          <p><a href={`mailto:${company.email}`}>{company.email}</a></p>
        </div>
        <div class="info-item" data-reveal>
          <h4>Registration</h4>
          <p>{company.rc}</p>
        </div>
        <div class="info-item" data-reveal>
          <h4>Follow us</h4>
          <div class="social">
            {socials.map((s) => (
              <a href={s.href} aria-label={s.label}>
                {s.label === "LinkedIn"
                  ? <svg viewBox="0 0 24 24" fill="currentColor"><path d="M4.98 3.5A2.5 2.5 0 1 1 5 8.5a2.5 2.5 0 0 1 0-5zM3 9h4v12H3zM10 9h3.8v1.7h.05c.53-1 1.84-2 3.8-2 4 0 4.75 2.6 4.75 6V21H19v-5c0-1.2 0-2.7-1.7-2.7s-2 1.3-2 2.6V21h-4z"/></svg>
                  : <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h3l-7 8 8 12h-6l-5-7-5 7H2l8-9L2 2h6l4 6zm-1 18h2L7 4H5z"/></svg>}
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- FORM COLUMN -->
      <div class="contact-form-wrap on-dark">
        <span class="eyebrow on-dark" data-reveal>Send a message</span>
        <h2 data-reveal style="margin-bottom:1.6rem">How can we help?</h2>
        <ContactForm />
      </div>
    </div>
  </div></section>

  <!-- MAP -->
  <section class="map-section" aria-label="Office location">
    <iframe
      title="ISRION office location map"
      src={`https://www.google.com/maps?q=${mapQuery}&output=embed`}
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
    ></iframe>
  </section>
</BaseLayout>
