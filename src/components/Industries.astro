---
import { industries } from "../data/site";
const pad = (n: number) => String(n + 1).padStart(2, "0");
---
<section class="industries" id="industries"><div class="wrap">
  <div class="ind-head">
    <div>
      <span class="eyebrow" data-reveal>Where we work</span>
      <h2 data-reveal>Cross-sector expertise.</h2>
    </div>
    <a href="#contact" class="arrow-link" data-reveal>Discuss your sector
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
  </div>
  <div class="ind-grid">
    {industries.map((name, i) => (
      <div class="ind" data-reveal><span class="c">{pad(i)}</span><h4>{name}</h4></div>
    ))}
  </div>
</div></section>
