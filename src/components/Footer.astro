---
import { company, nav } from "../data/site";
---
<footer><div class="wrap">
  <div class="foot-grid">
    <div class="foot-brand">
      <a href="#home" class="brand"><span class="mark">I</span>
        <span><b style="color:#fff">{company.short}</b><small style="color:rgba(255,255,255,.6)">International Ltd</small></span></a>
      <p>A multidisciplinary consulting, technology, engineering and sustainability firm committed to economic development, environmental protection and long-term sustainability.</p>
      <div class="social">
        <a href="#" aria-label="LinkedIn"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M4.98 3.5A2.5 2.5 0 1 1 5 8.5a2.5 2.5 0 0 1 0-5zM3 9h4v12H3zM10 9h3.8v1.7h.05c.53-1 1.84-2 3.8-2 4 0 4.75 2.6 4.75 6V21H19v-5c0-1.2 0-2.7-1.7-2.7s-2 1.3-2 2.6V21h-4z"/></svg></a>
        <a href="#" aria-label="X"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h3l-7 8 8 12h-6l-5-7-5 7H2l8-9L2 2h6l4 6zm-1 18h2L7 4H5z"/></svg></a>
      </div>
    </div>
    <div><h5>Explore</h5><ul>
      {nav.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
    </ul></div>
    <div><h5>Company</h5><ul>
      <li><a href="#about">About</a></li>
      <li><a href="#about">Leadership</a></li>
      <li><a href="#contact">Contact</a></li>
    </ul></div>
    <div><h5>Contact</h5><ul>
      <li><a href={`mailto:${company.email}`}>{company.email}</a></li>
      <li>Flat 2, Block 59 Kubwa II,<br/>Kubwa, FCT, Nigeria</li>
      <li>{company.rc}</li>
    </ul></div>
  </div>
  <div class="foot-bot">
    <span>© <span data-year></span> {company.name}</span>
    <span>{company.tagline}</span>
  </div>
</div></footer>
