---
import { values } from "../data/site";
---
<section class="statement" id="why"><div class="wrap"><div class="grid">
  <div>
    <span class="eyebrow" data-reveal>Who we are</span>
    <h2 data-reveal>Integrated answers to <span class="hl">interconnected</span> challenges.</h2>
  </div>
  <div class="body">
    <p data-reveal>ISRION International Ltd combines technical expertise, advanced technologies and industry best practice to help governments, industries, development agencies and communities grow sustainably — without trading off environmental responsibility or operational efficiency.</p>
    <p data-reveal>Food, energy, water, climate and biodiversity are not separate problems. We work across disciplines so the answer to one never becomes the cause of another.</p>
    <div class="values">
      {values.map((v) => (
        <div class="value" data-reveal><h4>{v.title}</h4><p>{v.body}</p></div>
      ))}
    </div>
  </div>
</div></div></section>
