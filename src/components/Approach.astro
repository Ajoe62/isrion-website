---
import { steps } from "../data/site";
---
<section class="approach" id="approach"><div class="wrap">
  <span class="eyebrow" data-reveal>How we work</span>
  <h2 data-reveal>A clear path from question to outcome.</h2>
  <div class="steps">
    {steps.map((s) => (
      <div class="step" data-reveal>
        <span class="num">{s.num}</span>
        <h4>{s.title}</h4>
        <p>{s.body}</p>
      </div>
    ))}
  </div>
</div></section>
