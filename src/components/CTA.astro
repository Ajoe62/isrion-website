---
import { company } from "../data/site";
---
<section class="cta" id="contact"><div class="wrap">
  <span class="eyebrow on-dark" data-reveal style="justify-content:center">Start a project</span>
  <h2 data-reveal>Ready to deliver sustainable results together?</h2>
  <p data-reveal>Whether you're a government agency, industry leader or development organisation, our team is ready to support your next project with technical depth and global standards.</p>

  <!--
    Netlify Forms: works automatically once deployed to Netlify — no backend.
    `data-astro-reload` lets the native POST bypass View Transitions.
    Locally (npm run dev) the form renders but submissions only process on Netlify.
  -->
  <form
    name="contact"
    method="POST"
    data-netlify="true"
    netlify-honeypot="bot-field"
    data-astro-reload
    class="contact-form"
    data-reveal
  >
    <input type="hidden" name="form-name" value="contact" />
    <p hidden><label>Don't fill this out: <input name="bot-field" /></label></p>

    <div class="row2">
      <label>Name<input type="text" name="name" required autocomplete="name" /></label>
      <label>Email<input type="email" name="email" required autocomplete="email" /></label>
    </div>
    <label>Organisation<input type="text" name="organisation" autocomplete="organization" /></label>
    <label>How can we help?<textarea name="message" rows="4" required></textarea></label>
    <button type="submit" class="btn btn-primary">Send message
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg></button>
  </form>

  <p class="alt" data-reveal>Prefer email? <a href={`mailto:${company.email}`}>{company.email}</a></p>
</div></section>

<style>
  .contact-form{max-width:620px;margin:2.4rem auto 0;text-align:left;display:grid;gap:1.1rem}
  .row2{display:grid;grid-template-columns:1fr 1fr;gap:1.1rem}
  .contact-form label{display:grid;gap:.45rem;font-family:"Space Mono",monospace;font-size:.66rem;
    letter-spacing:.16em;text-transform:uppercase;color:rgba(255,255,255,.8)}
  .contact-form input,.contact-form textarea{font-family:"Manrope";font-size:1rem;color:#fff;
    background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.22);border-radius:12px;
    padding:.85rem 1rem;letter-spacing:0;text-transform:none;transition:border-color .25s,background .25s}
  .contact-form input:focus,.contact-form textarea:focus{outline:none;border-color:#fff;background:rgba(255,255,255,.14)}
  .contact-form textarea{resize:vertical;min-height:110px}
  .contact-form button{justify-self:start;margin-top:.4rem}
  .cta .alt{margin-top:1.4rem;font-size:.9rem}
  .cta .alt a{color:#fff;text-decoration:underline;text-underline-offset:3px}
  @media(max-width:560px){.row2{grid-template-columns:1fr}}
</style>
