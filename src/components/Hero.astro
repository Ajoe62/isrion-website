---
import { company } from "../data/site";
---
<section class="hero" id="home">
  <div class="hero-video-bg" aria-hidden="true">
    <video id="heroVid0" class="hero-vid" autoplay muted playsinline>
      <source src="/hero.mp4" type="video/mp4" />
    </video>
    <video id="heroVid1" class="hero-vid" muted playsinline>
      <source src="/hero1.mp4" type="video/mp4" />
    </video>
  </div>
  <canvas id="contour" aria-hidden="true"></canvas>
  <div class="hero-glow" aria-hidden="true"></div>
  <div class="hero-vignette" aria-hidden="true"></div>
  <div class="wrap on-dark">
    <span class="eyebrow on-dark" data-reveal>{company.coords}</span>
    <h1 data-stagger>
      <span data-mask><span>Innovative solutions for a</span></span>
      <span data-mask><span><em>sustainable</em> future.</span></span>
    </h1>
    <p class="lead" data-reveal>A multidisciplinary consulting, technology, engineering and sustainability firm — turning environmental, geospatial and energy challenges into data-driven, buildable outcomes.</p>
    <div class="hero-actions" data-reveal>
      <a href="/services" class="btn btn-primary">Explore our services
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
      <a href="/contact" class="btn btn-ghost">Talk to our team</a>
    </div>
    <div class="hero-meta" data-reveal>
      <div><span class="n" data-count="8">0</span><span class="l">Service domains</span></div>
      <div><span class="n" data-count="12">0</span><span class="l">Sectors served</span></div>
      <div><span class="n">{company.founded}</span><span class="l">Founded · FCT</span></div>
    </div>
  </div>
  <div class="scroll-hint" aria-hidden="true"><span>Scroll</span><span class="bar"></span></div>
</section>
