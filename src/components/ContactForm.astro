---
import { company } from "../data/site";
---
<!--
  Formspree: host-agnostic (works on Vercel, Cloudflare Pages, etc.) — no backend.
  Submits via fetch() so the visitor stays on the page; `_gotcha` is the spam honeypot.
  Set the form ID in src/data/site.ts (company.formspreeId).
-->
<form
  method="POST"
  action={`https://formspree.io/f/${company.formspreeId}`}
  class="contact-form"
  data-reveal
  id="contactForm"
>
  <input type="hidden" name="_subject" value="New enquiry — ISRION website" />
  <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" style="display:none" aria-hidden="true" />

  <div class="row2">
    <label>Name<input type="text" name="name" required autocomplete="name" /></label>
    <label>Email<input type="email" name="email" required autocomplete="email" /></label>
  </div>
  <label>Organisation<input type="text" name="organisation" autocomplete="organization" /></label>
  <label>How can we help?<textarea name="message" rows="5" required></textarea></label>
  <button type="submit" class="btn btn-primary">Send message
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg></button>
  <p class="form-status" role="status" aria-live="polite" hidden></p>
</form>

<script>
  function wireContactForm() {
    const form = document.getElementById("contactForm") as HTMLFormElement | null;
    if (!form || form.dataset.wired) return;
    form.dataset.wired = "true";
    const status = form.querySelector<HTMLElement>(".form-status");
    const btn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
    const show = (msg: string, ok: boolean) => {
      if (!status) return;
      status.hidden = false;
      status.textContent = msg;
      status.classList.toggle("ok", ok);
      status.classList.toggle("err", !ok);
    };

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (btn) { btn.disabled = true; btn.dataset.label = btn.textContent || ""; btn.textContent = "Sending…"; }
      try {
        const res = await fetch(form.action, {
          method: "POST",
          body: new FormData(form),
          headers: { Accept: "application/json" },
        });
        if (res.ok) {
          form.reset();
          show("Thanks — your message has been sent. We'll be in touch shortly.", true);
        } else {
          const data = await res.json().catch(() => null);
          const msg = data?.errors?.map((x: { message: string }) => x.message).join(", ");
          show(msg || "Something went wrong. Please email us directly.", false);
        }
      } catch {
        show("Network error. Please email us directly.", false);
      } finally {
        if (btn) { btn.disabled = false; btn.textContent = btn.dataset.label || "Send message"; }
      }
    });
  }
  wireContactForm();
  document.addEventListener("astro:page-load", wireContactForm);
</script>

<style>
  .contact-form{display:grid;gap:1.1rem}
  .row2{display:grid;grid-template-columns:1fr 1fr;gap:1.1rem}
  .contact-form label{display:grid;gap:.45rem;font-family:"Space Mono",monospace;font-size:.66rem;
    letter-spacing:.16em;text-transform:uppercase;color:rgba(255,255,255,.8)}
  .contact-form input,.contact-form textarea{font-family:"Manrope";font-size:1rem;color:#fff;
    background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.22);border-radius:12px;
    padding:.85rem 1rem;letter-spacing:0;text-transform:none;transition:border-color .25s,background .25s}
  .contact-form input:focus,.contact-form textarea:focus{outline:none;border-color:#fff;background:rgba(255,255,255,.14)}
  .contact-form textarea{resize:vertical;min-height:120px}
  .contact-form button{justify-self:start;margin-top:.4rem}
  .contact-form button:disabled{opacity:.65;cursor:default}
  .form-status{font-family:"Manrope";font-size:.92rem;letter-spacing:0;text-transform:none;margin-top:.2rem}
  .form-status.ok{color:#bff3d4}
  .form-status.err{color:#ffc9c9}
  @media(max-width:560px){.row2{grid-template-columns:1fr}}
</style>
